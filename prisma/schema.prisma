generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id          String          @id @default(uuid())
  name        String          @unique
  nationality String
  iplTeams    PlayerIPLTeam[]
  topStats    TopPerformer[]
}

model IPLTeam {
  id      String          @id @default(uuid())
  code    String          @unique
  name    String
  players PlayerIPLTeam[]
}

model PlayerIPLTeam {
  playerId String
  player   Player  @relation(fields: [playerId], references: [id])
  teamId   String
  team     IPLTeam @relation(fields: [teamId], references: [id])
  @@id([playerId, teamId])
}

model Feedback {
  id          String   @id @default(uuid())
  type        String   @default("report") // report, add, invalid_pair
  playerId    String?
  playerName  String?
  teamCode    String?
  pairType    String?  // team_metric, metric_metric
  criterionAType  String?
  criterionACode  String?
  criterionALabel String?
  criterionBType  String?
  criterionBCode  String?
  criterionBLabel String?
  note        String?
  createdAt   DateTime @default(now())
  status      String   @default("pending") // pending, reviewed, added, rejected
}

model HardGridRule {
  id              String   @id @default(uuid())
  ruleType        String   // pair, criterion
  pairType        String?  // team_metric, metric_metric
  criterionAType  String?
  criterionACode  String?
  criterionALabel String?
  criterionBType  String?
  criterionBCode  String?
  criterionBLabel String?
  criterionType   String?  // team, metric
  criterionCode   String?
  criterionLabel  String?
  active          Boolean  @default(true)
  note            String?
  sourceFeedbackId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TopPerformer {
  id            String   @id @default(uuid())
  team          String
  statType      String   
  rank          Int
  playerName    String   // Purana "player" ab "playerName" ban gaya
  span          String
  matches       Int?
  specificStats Json
  
  // Linking columns
  playerId      String?  
  player        Player?  @relation(fields: [playerId], references: [id])
}